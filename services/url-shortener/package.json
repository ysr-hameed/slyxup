{
  "name": "@slyxup/url-shortener",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8003",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply slyxup-url-shortener --local",
    "db:migrate:remote": "wrangler d1 migrations apply slyxup-url-shortener --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "drizzle-orm": "^0.42.0",
    "jose": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "wrangler": "^4.0.0",
    "typescript": "^5.7.0",
    "drizzle-kit": "^0.30.0"
  }
}
