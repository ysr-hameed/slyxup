{
  "name": "slyxup",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:auth": "pnpm --filter @slyxup/auth-service dev",
    "dev:billing": "pnpm --filter @slyxup/billing-service dev",
    "dev:email": "pnpm --filter @slyxup/email-service dev",
    "dev:analytics": "pnpm --filter @slyxup/analytics-service dev",
    "dev:storage": "pnpm --filter @slyxup/storage-service dev",
    "dev:admin": "pnpm --filter @slyxup/admin-service dev",
    "dev:notification": "pnpm --filter @slyxup/notification-service dev",
    "deploy:auth": "pnpm --filter @slyxup/auth-service deploy",
    "deploy:billing": "pnpm --filter @slyxup/billing-service deploy",
    "deploy:email": "pnpm --filter @slyxup/email-service deploy",
    "deploy:analytics": "pnpm --filter @slyxup/analytics-service deploy",
    "deploy:storage": "pnpm --filter @slyxup/storage-service deploy",
    "deploy:admin": "pnpm --filter @slyxup/admin-service deploy",
    "deploy:notification": "pnpm --filter @slyxup/notification-service deploy",
    "db:migrate:auth": "wrangler d1 migrations apply slyxup-auth --local",
    "db:migrate:billing": "wrangler d1 migrations apply slyxup-billing --local",
    "db:migrate:analytics": "wrangler d1 migrations apply slyxup-analytics --local",
    "db:migrate:admin": "wrangler d1 migrations apply slyxup-admin --local",
    "db:migrate:notification": "wrangler d1 migrations apply slyxup-notification --local",
    "typecheck": "pnpm -r run typecheck",
    "start": "./start.sh"
  },
  "engines": {
    "node": ">=22"
  }
}
