{
  "name": "slyxup",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:auth": "pnpm --filter @slyxup/auth dev",
    "dev:payment": "pnpm --filter @slyxup/payment dev",
    "dev:admin": "pnpm --filter @slyxup/admin dev",
    "dev:web": "pnpm --filter @slyxup/web dev",
    "deploy:auth": "pnpm --filter @slyxup/auth deploy",
    "deploy:payment": "pnpm --filter @slyxup/payment deploy",
    "deploy:admin": "pnpm --filter @slyxup/admin deploy",
    "deploy:web": "pnpm --filter @slyxup/web deploy",
    "db:create:auth": "wrangler d1 create slyxup-auth",
    "db:create:payment": "wrangler d1 create slyxup-payment",
    "db:create:admin": "wrangler d1 create slyxup-admin",
    "db:generate": "drizzle-kit generate --config=packages/shared-db/drizzle.config.ts",
    "db:migrate:auth": "wrangler d1 migrations apply slyxup-auth --local",
    "db:migrate:payment": "wrangler d1 migrations apply slyxup-payment --local",
    "db:migrate:admin": "wrangler d1 migrations apply slyxup-admin --local",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write ."
  },
  "engines": {
    "node": ">=22"
  }
}
