{
  "info": {
    "name": "Slyxup API (Local)",
    "description": "Auth (8000) + Payment (8001) + Admin (8002)\n\n1. cd services/auth && pnpm dev\n2. cd services/payment && pnpm dev\n3. cd services/admin && pnpm dev",
    "schema": "https://schema.getpostman.com/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "auth_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "payment_url", "value": "http://localhost:8001", "type": "string" },
    { "key": "admin_url", "value": "http://localhost:8002", "type": "string" },
    { "key": "jwt", "value": "", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "admin_jwt", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["const res = pm.response.json();", "if(res.success) pm.collectionVariables.set('userId', res.data.userId);"],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Test1234!\",\n  \"name\": \"Test User\"\n}" },
            "url": { "raw": "{{auth_url}}/api/auth/register", "host": ["{{auth_url}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["const res = pm.response.json();", "if(res.success) {", "  pm.collectionVariables.set('jwt', res.data.jwt);", "  pm.collectionVariables.set('token', res.data.token);", "}"],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Test1234!\"\n}" },
            "url": { "raw": "{{auth_url}}/api/auth/login", "host": ["{{auth_url}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Verify JWT",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": { "raw": "{{auth_url}}/api/auth/verify", "host": ["{{auth_url}}"], "path": ["api", "auth", "verify"] }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": { "raw": "{{auth_url}}/api/auth/me", "host": ["{{auth_url}}"], "path": ["api", "auth", "me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{token}}\"\n}" },
            "url": { "raw": "{{auth_url}}/api/auth/logout", "host": ["{{auth_url}}"], "path": ["api", "auth", "logout"] }
          }
        },
        {
          "name": "Invalid Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"notanemail\",\n  \"password\": \"Test1234!\"\n}" },
            "url": { "raw": "{{auth_url}}/api/auth/register", "host": ["{{auth_url}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Weak Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"weak@test.com\",\n  \"password\": \"short\"\n}" },
            "url": { "raw": "{{auth_url}}/api/auth/register", "host": ["{{auth_url}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Wrong Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"WrongPass1!\"\n}" },
            "url": { "raw": "{{auth_url}}/api/auth/login", "host": ["{{auth_url}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "No Auth Header",
          "request": {
            "method": "GET",
            "url": { "raw": "{{auth_url}}/api/auth/me", "host": ["{{auth_url}}"], "path": ["api", "auth", "me"] }
          }
        },
        {
          "name": "Bad JWT",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer invalidtoken" }],
            "url": { "raw": "{{auth_url}}/api/auth/verify", "host": ["{{auth_url}}"], "path": ["api", "auth", "verify"] }
          }
        },
        {
          "name": "404 Not Found",
          "request": {
            "method": "GET",
            "url": { "raw": "{{auth_url}}/api/auth/nonexistent", "host": ["{{auth_url}}"], "path": ["api", "auth", "nonexistent"] }
          }
        }
      ]
    },
    {
      "name": "Payment",
      "item": [
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"priceId\": \"pri_xxxxx\",\n  \"userId\": \"test-user-id\",\n  \"returnUrl\": \"https://example.com/success\"\n}" },
            "url": { "raw": "{{payment_url}}/api/payment/checkout", "host": ["{{payment_url}}"], "path": ["api", "payment", "checkout"] }
          }
        },
        {
          "name": "Checkout Missing Fields",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{payment_url}}/api/payment/checkout", "host": ["{{payment_url}}"], "path": ["api", "payment", "checkout"] }
          }
        },
        {
          "name": "Get Subscription",
          "request": {
            "method": "GET",
            "url": { "raw": "{{payment_url}}/api/payment/subscription?userId=test-user-id", "host": ["{{payment_url}}"], "path": ["api", "payment", "subscription"], "query": [{ "key": "userId", "value": "test-user-id" }] }
          }
        },
        {
          "name": "Subscription No userId",
          "request": {
            "method": "GET",
            "url": { "raw": "{{payment_url}}/api/payment/subscription", "host": ["{{payment_url}}"], "path": ["api", "payment", "subscription"] }
          }
        },
        {
          "name": "Customer Portal",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"customerId\": \"cus_xxxxx\",\n  \"returnUrl\": \"https://example.com/portal\"\n}" },
            "url": { "raw": "{{payment_url}}/api/payment/portal", "host": ["{{payment_url}}"], "path": ["api", "payment", "portal"] }
          }
        },
        {
          "name": "Portal No customerId",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{payment_url}}/api/payment/portal", "host": ["{{payment_url}}"], "path": ["api", "payment", "portal"] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Register Admin",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["const res = pm.response.json();", "if(res.success) console.log('Admin created:', res.data.adminId);"],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@slyxup.com\",\n  \"password\": \"Admin1234!\",\n  \"secret\": \"superadmin-secret-2026\"\n}" },
            "url": { "raw": "{{admin_url}}/api/admin/register", "host": ["{{admin_url}}"], "path": ["api", "admin", "register"] }
          }
        },
        {
          "name": "Register No Secret",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"hacker@test.com\",\n  \"password\": \"Hack1234!\"\n}" },
            "url": { "raw": "{{admin_url}}/api/admin/register", "host": ["{{admin_url}}"], "path": ["api", "admin", "register"] }
          }
        },
        {
          "name": "Login Admin",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["const res = pm.response.json();", "if(res.success) pm.collectionVariables.set('admin_jwt', res.data.jwt);"],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@slyxup.com\",\n  \"password\": \"Admin1234!\"\n}" },
            "url": { "raw": "{{admin_url}}/api/admin/login", "host": ["{{admin_url}}"], "path": ["api", "admin", "login"] }
          }
        },
        {
          "name": "List Admins",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_jwt}}" }],
            "url": { "raw": "{{admin_url}}/api/admin/users", "host": ["{{admin_url}}"], "path": ["api", "admin", "users"] }
          }
        },
        {
          "name": "Auth Tests (integration)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_jwt}}" }],
            "url": { "raw": "{{admin_url}}/api/admin/test/auth", "host": ["{{admin_url}}"], "path": ["api", "admin", "test", "auth"] }
          }
        },
        {
          "name": "Payment Tests (integration)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_jwt}}" }],
            "url": { "raw": "{{admin_url}}/api/admin/test/payment", "host": ["{{admin_url}}"], "path": ["api", "admin", "test", "payment"] }
          }
        },
        {
          "name": "Test Results",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_jwt}}" }],
            "url": { "raw": "{{admin_url}}/api/admin/test/results?limit=10", "host": ["{{admin_url}}"], "path": ["api", "admin", "test", "results"], "query": [{ "key": "limit", "value": "10" }] }
          }
        },
        {
          "name": "Audit Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_jwt}}" }],
            "url": { "raw": "{{admin_url}}/api/admin/audit?limit=10", "host": ["{{admin_url}}"], "path": ["api", "admin", "audit"], "query": [{ "key": "limit", "value": "10" }] }
          }
        },
        {
          "name": "Unauthorized (no JWT)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{admin_url}}/api/admin/users", "host": ["{{admin_url}}"], "path": ["api", "admin", "users"] }
          }
        },
        {
          "name": "Invalid Admin JWT",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer badtoken" }],
            "url": { "raw": "{{admin_url}}/api/admin/users", "host": ["{{admin_url}}"], "path": ["api", "admin", "users"] }
          }
        }
      ]
    }
  ]
}
